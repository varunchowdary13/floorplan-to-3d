{
  "name": "floorplan3d-pro",
  "version": "1.0.0",
  "description": "Civil architecture design tool - Blender for civil engineers",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "server": "python server/main.py",
    "dev": "electron . && python server/main.py",
    "build": "electron-builder --win"
  },
  "author": "Varun",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.varun.floorplan3dpro",
    "productName": "FloorPlan 3D Pro",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "files": ["src/**/*", "server/**/*"],
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      }
    ]
  }
}
