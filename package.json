{
  "name": "floorplan-3d-builder",
  "version": "1.0.0",
  "description": "Floor plan builder + 3D converter for architectural design",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "Varun",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.varun.floorplan3d",
    "productName": "FloorPlan 3D Builder",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "files": ["src/**/*"]
  }
}
