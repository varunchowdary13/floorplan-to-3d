{
  "name": "floorplan-to-3d",
  "version": "1.0.0",
  "description": "Convert architectural floor plans to 3D house models",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --win"
  },
  "author": "Varun",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.varun.floorplan3d",
    "productName": "FloorPlan to 3D",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "files": ["src/**/*"]
  }
}
